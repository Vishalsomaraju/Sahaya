datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  PATIENT
  ASHA
  DOCTOR
}

enum AssessmentPriority {
  LOW
  MEDIUM
  HIGH
}

enum AssessmentStatus {
  PENDING
  REVIEWED
  RESOLVED
}

enum ConsultationStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
}

enum FacilityType {
  PHC
  CHC
}

model User {
  id           String   @id @default(uuid())
  name         String
  phone        String   @unique
  email        String?  @unique
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())

  patientProfile PatientProfile?
  ashaProfile    AshaProfile?
  doctorProfile  DoctorProfile?

  assessmentsAsPatient   Assessment[]   @relation("PatientAssessments")
  assessmentsSubmittedBy Assessment[]   @relation("SubmittedByAssessments")
  consultationsAsPatient Consultation[] @relation("PatientConsultations")
  consultationsAsDoctor  Consultation[] @relation("DoctorConsultations")
  vitals                 Vitals[]

  @@index([role])
}

model PatientProfile {
  userId          String   @id
  dateOfBirth     DateTime
  gender          String
  villageSector   String
  guardianContact String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AshaProfile {
  userId     String @id
  sector     String
  employeeId String @unique

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DoctorProfile {
  userId         String @id
  specialization String
  licenseNumber  String @unique

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Assessment {
  id               String             @id @default(uuid())
  patientId        String
  submittedById    String
  symptoms         String[]
  vitals           Json?
  aiSummary        String?
  aiRecommendation String?
  priority         AssessmentPriority
  status           AssessmentStatus   @default(PENDING)
  createdAt        DateTime           @default(now())

  patient       User           @relation("PatientAssessments", fields: [patientId], references: [id])
  submittedBy   User           @relation("SubmittedByAssessments", fields: [submittedById], references: [id])
  vitalsLog     Vitals[]
  consultations Consultation[]

  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@index([patientId])
}

model Vitals {
  id               String   @id @default(uuid())
  assessmentId     String?
  patientId        String?
  device           String?
  heartRate        Int?
  restingHeartRate Int?
  steps            Int?
  distance         Float?
  calories         Int?
  sleepMinutes     Int?
  spo2             Int?
  temperature      Float?
  bloodPressure    String?
  recordedAt       DateTime @default(now())

  assessment Assessment? @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  patient    User?       @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

model Consultation {
  id           String             @id @default(uuid())
  assessmentId String
  doctorId     String
  patientId    String
  status       ConsultationStatus @default(SCHEDULED)
  scheduledAt  DateTime
  notes        String?

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  doctor     User       @relation("DoctorConsultations", fields: [doctorId], references: [id])
  patient    User       @relation("PatientConsultations", fields: [patientId], references: [id])

  @@index([status])
  @@index([scheduledAt])
}

model Facility {
  id        String       @id @default(uuid())
  name      String
  type      FacilityType
  latitude  Float
  longitude Float
  address   String
  hoursOpen String
}
